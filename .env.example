# Postgres (Neon 권장 — https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/algostudy?sslmode=require"

TEST_DATABASE_URL="postgresql://user:password@localhost:5432/algostudy_test"

# cron 엔드포인트 보호용 시크릿 (Vercel Cron 호출 시 Authorization: Bearer <이 값>)
CRON_SECRET="change-me-to-a-long-random-string"

# (선택) 마감 결과/리마인더를 보낼 Discord Webhook
DISCORD_WEBHOOK_URL=""

# 그룹 주 경계 계산 기본 타임존
DEFAULT_TIMEZONE="Asia/Seoul"

# ── 인증 (GitHub OAuth via Auth.js) ──
# 아무 랜덤 문자열 (예: openssl rand -base64 32)
AUTH_SECRET="change-me-random"
# GitHub → Settings → Developer settings → OAuth Apps 에서 발급
#   Homepage URL:        https://<your-app>.vercel.app
#   Authorization callback URL: https://<your-app>.vercel.app/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

ADMIN_GITHUB_ID=""

GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""
GITHUB_APP_WEBHOOK_SECRET=""
