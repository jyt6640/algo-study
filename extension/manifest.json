{
  "manifest_version": 3,
  "name": "7일 7솔 — 알고리즘 스터디 업로더",
  "version": "0.6.2",
  "description": "LeetCode·프로그래머스에서 정답 처리되면 제출 코드를 자동으로 감지해 스터디에 업로드합니다.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://school.programmers.co.kr/*",
    "https://algo-study-eight.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "7일 7솔",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://school.programmers.co.kr/learn/courses/*/lessons/*"],
      "js": ["content-programmers.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://algo-study-eight.vercel.app/*", "http://localhost:3000/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://leetcode.com/*"]
    },
    {
      "resources": ["inject-programmers.js"],
      "matches": ["https://school.programmers.co.kr/*"]
    }
  ]
}
